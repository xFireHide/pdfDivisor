{
  "version": 2,
  "builds": [
    { "src": "api.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api.py", "dest": "/api.py" },
    { "src": "/", "dest": "/index.html" }
  ]
}
